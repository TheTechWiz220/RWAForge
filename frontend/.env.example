# Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Program IDs — set after `anchor keys list` / deploy (must be valid base58 pubkeys)
# Leave unset to use built-in dev placeholders (System / SPL Token / Token-2022 programs)
# NEXT_PUBLIC_RWA_TOKENIZATION_PROGRAM_ID=
# NEXT_PUBLIC_RWA_MARKETPLACE_PROGRAM_ID=
# NEXT_PUBLIC_RWA_TRANSFER_HOOK_PROGRAM_ID=

# USDC devnet mint
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14G2XhfaJVjQwpNwgkZUtZYHj6jGrt

# AI Provider: openai | anthropic | groq
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
